{
  "family": "nexcore-saas-api-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::153106962722:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "nexcore-api",
      "image": "153106962722.dkr.ecr.us-east-1.amazonaws.com/nexcore-api:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "ALGORITHM",
          "value": "HS256"
        },
        {
          "name": "ACCESS_TOKEN_EXPIRE_MINUTES",
          "value": "60"
        },
        {
          "name": "STORAGE_TYPE",
          "value": "s3"
        },
        {
          "name": "AWS_REGION",
          "value": "us-east-1"
        },
        {
          "name": "AWS_S3_BUCKET",
          "value": "nexcore-saas-media-ccerks"
        },
        {
          "name": "STRIPE_PUBLISHABLE_KEY",
          "value": "pk_test_5cdscsdcwXM6ISoEF7XAoj6viQkIo4ZfvAIk00eAzQefO0"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/database_url"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/redis_url"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/secret_key"
        },
        {
          "name": "STRIPE_SECRET_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/stripe_secret_key"
        },
        {
          "name": "STRIPE_WEBHOOK_SECRET",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/stripe_webhook_secret"
        },
        {
          "name": "DISCORD_WEBHOOK_URL",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/discord_webhook_url"
        },
        {
          "name": "AWS_ACCESS_KEY_ID",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/aws_access_key_id"
        },
        {
          "name": "AWS_SECRET_ACCESS_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:153106962722:parameter/nexcore/prod/aws_secret_access_key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/nexcore-saas-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}